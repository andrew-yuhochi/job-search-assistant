# Job Search Assistant — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic API key for Claude Haiku duty classification + Citations API drafting
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SerpAPI key for Google Jobs scraping (free tier: 250 searches/month)
SERPAPI_API_KEY=your_serpapi_api_key_here

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Path to the SQLite database file (relative to project root)
DATABASE_PATH=data/app.db
